          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="fwd_a3T" value="+β_T noise" style="endArrow=classic;html=1;strokeColor=#b85450;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;"
