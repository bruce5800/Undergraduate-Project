  <diagram name="Diffusion Model Architecture" id="fig-diffusion">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1140" pageHeight="940" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ====== Title (centered over content, center ~570) ====== -->
        <mxCell id="title" value="Diffusion Model: Forward Noising + Reverse Denoising via U-Net (background)"
                style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;"
                vertex="1" parent="1">
          <mxGeometry x="70" y="20" width="1000" height="30" as="geometry" />
        </mxCell>

        <!-- ====== Schedule controller ====== -->
        <mxCell id="schedule" value="&lt;b&gt;Noise Schedule&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:11px;color:#555;'&gt;β_t (e.g. linear or cosine); defines noise level at every timestep t ∈ [0, T]&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="295" y="120" width="550" height="60" as="geometry" />
        </mxCell>

        <!-- ====== Forward Process section ====== -->
        <mxCell id="fwd_bar" value="① Forward Process — gradual noising: x_0 → x_T  (deterministic, no learnable params)"
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b85450;strokeColor=#b85450;fontColor=#FFFFFF;fontSize=13;fontStyle=1;align=left;spacingLeft=15;"
                vertex="1" parent="1">
          <mxGeometry x="50" y="220" width="1040" height="28" as="geometry" />
        </mxCell>

        <mxCell id="fwd_x0" value="&lt;b&gt;x_0&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#555;'&gt;clean image&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="100" y="270" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="fwd_x1" value="&lt;b&gt;x_{T/4}&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#555;'&gt;light noise&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fbe0df;strokeColor=#b85450;fontSize=11;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="300" y="270" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="fwd_x2" value="&lt;b&gt;x_{T/2}&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#555;'&gt;medium noise&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="500" y="270" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="fwd_x3" value="&lt;b&gt;x_{3T/4}&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#fff;'&gt;heavy noise&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c97f7c;strokeColor=#b85450;fontSize=11;fontColor=#FFFFFF;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="700" y="270" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="fwd_xT" value="&lt;b&gt;x_T&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#fff;'&gt;pure Gaussian noise&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9c4441;strokeColor=#b85450;fontSize=11;fontColor=#FFFFFF;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="900" y="270" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="fwd_a01" value="+β_1 noise" style="endArrow=classic;html=1;strokeColor=#b85450;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;"
                edge="1" parent="1" source="fwd_x0" target="fwd_x1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="fwd_a12" style="endArrow=classic;html=1;strokeColor=#b85450;strokeWidth=2;"
                edge="1" parent="1" source="fwd_x1" target="fwd_x2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="fwd_a23" style="endArrow=classic;html=1;strokeColor=#b85450;strokeWidth=2;"
