          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rev_a21" style="endArrow=classic;html=1;strokeColor=#6c8ebf;strokeWidth=2;"
                edge="1" parent="1" source="rev_x2" target="rev_x1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rev_a10" style="endArrow=classic;html=1;strokeColor=#6c8ebf;strokeWidth=2;"
                edge="1" parent="1" source="rev_x1" target="rev_x0">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ====== U-Net section ====== -->
        <mxCell id="unet_bar" value="③ U-Net Denoiser — shared network invoked at every reverse step (predicts ε given x_t, t)"
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d6b656;strokeColor=#d6b656;fontColor=#FFFFFF;fontSize=13;fontStyle=1;align=left;spacingLeft=15;"
                vertex="1" parent="1">
          <mxGeometry x="50" y="600" width="1040" height="28" as="geometry" />
        </mxCell>

        <mxCell id="unet_enc" value="&lt;b&gt;Encoder Block&lt;/b&gt;&lt;br&gt;&lt;br&gt;down-sampling path&lt;br&gt;&lt;span style='font-size:10px;color:#555;'&gt;Conv + ResBlocks&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="150" y="650" width="240" height="140" as="geometry" />
        </mxCell>

        <mxCell id="unet_mid" value="&lt;b&gt;Bottleneck&lt;/b&gt;&lt;br&gt;&lt;br&gt;self-attention&lt;br&gt;&lt;span style='font-size:10px;color:#555;'&gt;+ time embedding&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="500" y="650" width="240" height="140" as="geometry" />
        </mxCell>

        <mxCell id="unet_dec" value="&lt;b&gt;Decoder Block&lt;/b&gt;&lt;br&gt;&lt;br&gt;up-sampling path&lt;br&gt;&lt;span style='font-size:10px;color:#555;'&gt;ConvTranspose + ResBlocks&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="850" y="650" width="240" height="140" as="geometry" />
        </mxCell>

        <mxCell id="unet_e_m" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d6b656;strokeWidth=2;"
                edge="1" parent="1" source="unet_enc" target="unet_mid">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="unet_m_d" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d6b656;strokeWidth=2;"
                edge="1" parent="1" source="unet_mid" target="unet_dec">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="unet_skip" value="skip connection"
