          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ====== Bottom note ====== -->
        <mxCell id="footnote" value="&lt;i&gt;In our simulation: each diffusion request runs reverse-process steps_default times (e.g. SDXL = 30), each step = a U-Net forward pass.&lt;/i&gt;"
