          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ====== Reverse Process section ====== -->
        <mxCell id="rev_bar" value="② Reverse Process — learned denoising: x_T → x_0  (each step calls U-Net to predict noise ε_θ)"
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#6c8ebf;fontColor=#FFFFFF;fontSize=13;fontStyle=1;align=left;spacingLeft=15;"
                vertex="1" parent="1">
          <mxGeometry x="50" y="380" width="1040" height="28" as="geometry" />
        </mxCell>

        <mxCell id="rev_xT" value="&lt;b&gt;x_T&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#fff;'&gt;sampled noise&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#5a7a9a;strokeColor=#6c8ebf;fontSize=11;fontColor=#FFFFFF;verticalAlign=middle;align=center;"
