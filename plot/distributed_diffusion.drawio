          <mxGeometry x="700" y="430" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="rev_x0" value="&lt;b&gt;x_0&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#555;'&gt;generated image&lt;/span&gt;"
