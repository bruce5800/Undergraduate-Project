        <mxCell id="invoke_4" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.6;entryY=0;strokeColor=#d6b656;strokeWidth=1.5;dashed=1;"
                edge="1" parent="1" source="rev_x1" target="unet_dec">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ====== Schedule controls both processes ====== -->
        <mxCell id="sched_to_fwd" style="endArrow=classic;html=1;exitX=0.3;exitY=1;entryX=0.5;entryY=0;strokeColor=#9673a6;strokeWidth=1.5;dashed=1;"
