        <mxCell id="reward_box" value="&lt;b&gt;Base (load-balance):&lt;/b&gt; 0.25·time + 0.10·balance + 0.10·match&#10;&lt;b&gt;AIGC-aware:&lt;/b&gt; 0.15·warm + 0.20·batch + 0.10·affinity&#10;&lt;b&gt;Anti-collapse:&lt;/b&gt; 0.10·cloud-overuse"
