<mxfile host="app.diagrams.net" modified="2026-05-21T17:00:00.000Z" agent="Mozilla/5.0" version="22.1.0" type="device">
  <diagram name="Trace Integration" id="trace-arch">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1280" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ====== Title ====== -->
        <mxCell id="title" value="AIGC Inference Trace Integration Architecture (M4)"
                style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;"
                vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="700" height="30" as="geometry" />
        </mxCell>

        <!-- ====== Section 1: Trace Sources ====== -->
        <mxCell id="s1_bar" value="① Trace Sources"
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#9673a6;strokeColor=#9673a6;fontColor=#FFFFFF;fontSize=14;fontStyle=1;align=left;spacingLeft=15;"
                vertex="1" parent="1">
          <mxGeometry x="50" y="70" width="1300" height="28" as="geometry" />
        </mxCell>

        <mxCell id="src_uniform"
                value="&lt;b&gt;uniform preset&lt;/b&gt;&lt;br&gt;&lt;br&gt;prompt ∈ [64, 1024] tokens&lt;br&gt;output ∈ [50, 500] tokens&lt;br&gt;均匀随机采样"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;verticalAlign=top;spacingTop=10;"
                vertex="1" parent="1">
          <mxGeometry x="100" y="120" width="300" height="120" as="geometry" />
        </mxCell>

        <mxCell id="src_lognormal"
                value="&lt;b&gt;lognormal preset&lt;/b&gt;&lt;br&gt;&lt;br&gt;prompt ~ LogN(μ=5.5, σ=1.0)&lt;br&gt;output ~ LogN(μ=4.5, σ=1.2)&lt;br&gt;长尾分布（参 Azure trace）"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;verticalAlign=top;spacingTop=10;"
                vertex="1" parent="1">
          <mxGeometry x="550" y="120" width="300" height="120" as="geometry" />
        </mxCell>

        <mxCell id="src_catalog"
                value="&lt;b&gt;ModelCatalog&lt;/b&gt;&lt;br&gt;&lt;br&gt;llama-7b / llama-13b&lt;br&gt;llama-70b (INT8) / sdxl&lt;br&gt;Zipf(α=1.2) 模型选择"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;verticalAlign=top;spacingTop=10;"
                vertex="1" parent="1">
          <mxGeometry x="1000" y="120" width="300" height="120" as="geometry" />
        </mxCell>

        <!-- ====== Section 2: Workload Generator ====== -->
        <mxCell id="s2_bar" value="② Workload Generator (environment/task.py)"
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#6c8ebf;fontColor=#FFFFFF;fontSize=14;fontStyle=1;align=left;spacingLeft=15;"
                vertex="1" parent="1">
          <mxGeometry x="50" y="290" width="1300" height="28" as="geometry" />
        </mxCell>

        <mxCell id="gen_box"
                value="&lt;b&gt;Task.generate_inference_workload(N, rng, dist, arrival_rate)&lt;/b&gt;&lt;br&gt;&lt;br&gt;for each request i in [0, N):&lt;br&gt; • sample model_id from catalog&lt;br&gt; • sample prompt_tokens, output_tokens from dist&lt;br&gt; • arrival_time[i] = arrival_time[i-1] + Exp(arrival_rate)&lt;br&gt; • produce (Prefill, Decode) pair sharing req_id"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=top;spacingTop=10;align=left;spacingLeft=20;"
                vertex="1" parent="1">
          <mxGeometry x="200" y="340" width="1000" height="160" as="geometry" />
        </mxCell>

        <mxCell id="gen_output"
                value="N × (Prefill → Decode) DAG&lt;br&gt;&lt;span style=&quot;font-size:10px;color:#555;&quot;&gt;每个 task 携带：model_id, kind, prompt/output_tokens, arrival_time, kv_cache_GB&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4e1f5;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;"
                vertex="1" parent="1">
          <mxGeometry x="350" y="520" width="700" height="50" as="geometry" />
        </mxCell>

