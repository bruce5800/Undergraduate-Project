<mxfile host="app.diagrams.net" modified="2026-05-23T17:00:00.000Z" agent="Mozilla/5.0" version="22.1.0" type="device">
  <diagram name="Diffusion Model Architecture (ZH)" id="fig-diffusion-zh">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ====== 标题 ====== -->
        <mxCell id="title" value="扩散模型：前向加噪 + U-Net 反向去噪（背景知识）"
                style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;"
                vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="800" height="30" as="geometry" />
        </mxCell>

        <!-- ====== 图例 ====== -->
        <mxCell id="legend_box" value="&lt;b&gt;图例&lt;/b&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=12;verticalAlign=top;spacingTop=8;align=left;spacingLeft=10;"
                vertex="1" parent="1">
          <mxGeometry x="1110" y="120" width="270" height="130" as="geometry" />
        </mxCell>
        <mxCell id="legend_fwd" style="endArrow=classic;html=1;strokeColor=#b85450;strokeWidth=2;"
                edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1130" y="158" as="sourcePoint" />
            <mxPoint x="1190" y="158" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="legend_fwd_text" value="前向：q(x_t|x_t−1)"
                style="text;html=1;align=left;fontSize=11;"
                vertex="1" parent="1">
          <mxGeometry x="1200" y="148" width="170" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend_rev" style="endArrow=classic;html=1;strokeColor=#6c8ebf;strokeWidth=2;"
                edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1130" y="193" as="sourcePoint" />
            <mxPoint x="1190" y="193" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="legend_rev_text" value="反向：p_θ(x_t−1|x_t)"
                style="text;html=1;align=left;fontSize=11;"
                vertex="1" parent="1">
          <mxGeometry x="1200" y="183" width="170" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend_unet" style="endArrow=classic;html=1;strokeColor=#d6b656;strokeWidth=2;dashed=1;"
                edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1130" y="228" as="sourcePoint" />
            <mxPoint x="1190" y="228" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="legend_unet_text" value="U-Net 调用"
                style="text;html=1;align=left;fontSize=11;"
                vertex="1" parent="1">
          <mxGeometry x="1200" y="218" width="170" height="20" as="geometry" />
        </mxCell>

        <!-- ====== 噪声调度控制器 ====== -->
        <mxCell id="schedule" value="&lt;b&gt;噪声调度 (Noise Schedule)&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:11px;color:#555;'&gt;β_t（线性或余弦等）；定义每个 timestep t ∈ [0, T] 的噪声强度&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="380" y="120" width="550" height="60" as="geometry" />
        </mxCell>

        <!-- ====== 前向过程节区 ====== -->
        <mxCell id="fwd_bar" value="① 前向过程（Forward）—— 逐步加噪：x_0 → x_T（确定性，无可学参数）"
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b85450;strokeColor=#b85450;fontColor=#FFFFFF;fontSize=13;fontStyle=1;align=left;spacingLeft=15;"
                vertex="1" parent="1">
          <mxGeometry x="50" y="220" width="1040" height="28" as="geometry" />
        </mxCell>

        <!-- 5 个前向 timestep 状态：x_0 → x_T（从左到右，噪声渐增） -->
        <mxCell id="fwd_x0" value="&lt;b&gt;x_0&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#555;'&gt;干净图像&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="100" y="270" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="fwd_x1" value="&lt;b&gt;x_{T/4}&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#555;'&gt;轻度噪声&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fbe0df;strokeColor=#b85450;fontSize=11;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="300" y="270" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="fwd_x2" value="&lt;b&gt;x_{T/2}&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#555;'&gt;中度噪声&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="500" y="270" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="fwd_x3" value="&lt;b&gt;x_{3T/4}&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#fff;'&gt;重度噪声&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c97f7c;strokeColor=#b85450;fontSize=11;fontColor=#FFFFFF;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="700" y="270" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="fwd_xT" value="&lt;b&gt;x_T&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#fff;'&gt;纯高斯噪声&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9c4441;strokeColor=#b85450;fontSize=11;fontColor=#FFFFFF;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="900" y="270" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- 前向箭头 -->
        <mxCell id="fwd_a01" value="+β_1 噪声" style="endArrow=classic;html=1;strokeColor=#b85450;strokeWidth=2;fontSize=10;verticalAlign=bottom;"
                edge="1" parent="1" source="fwd_x0" target="fwd_x1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="fwd_a12" style="endArrow=classic;html=1;strokeColor=#b85450;strokeWidth=2;"
                edge="1" parent="1" source="fwd_x1" target="fwd_x2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="fwd_a23" style="endArrow=classic;html=1;strokeColor=#b85450;strokeWidth=2;"
                edge="1" parent="1" source="fwd_x2" target="fwd_x3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="fwd_a3T" value="+β_T 噪声" style="endArrow=classic;html=1;strokeColor=#b85450;strokeWidth=2;fontSize=10;verticalAlign=bottom;"
                edge="1" parent="1" source="fwd_x3" target="fwd_xT">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ====== 反向过程节区 ====== -->
        <mxCell id="rev_bar" value="② 反向过程（Reverse）—— 学习式去噪：x_T → x_0（每步调用 U-Net 预测噪声 ε_θ）"
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#6c8ebf;fontColor=#FFFFFF;fontSize=13;fontStyle=1;align=left;spacingLeft=15;"
                vertex="1" parent="1">
          <mxGeometry x="50" y="380" width="1040" height="28" as="geometry" />
        </mxCell>

        <!-- 5 个反向 timestep 状态：x_T → x_0（沿迭代顺序从左到右） -->
        <mxCell id="rev_xT" value="&lt;b&gt;x_T&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#fff;'&gt;采样自高斯&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#5a7a9a;strokeColor=#6c8ebf;fontSize=11;fontColor=#FFFFFF;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="100" y="430" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="rev_x3" value="&lt;b&gt;x_{3T/4}&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#fff;'&gt;噪声减少&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7d9bb7;strokeColor=#6c8ebf;fontSize=11;fontColor=#FFFFFF;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="300" y="430" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="rev_x2" value="&lt;b&gt;x_{T/2}&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#555;'&gt;更清晰&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="500" y="430" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="rev_x1" value="&lt;b&gt;x_{T/4}&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#555;'&gt;接近干净&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ebf2fb;strokeColor=#6c8ebf;fontSize=11;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="700" y="430" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="rev_x0" value="&lt;b&gt;x_0&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px;color:#555;'&gt;生成图像&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="900" y="430" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- 反向箭头 -->
        <mxCell id="rev_aT3" style="endArrow=classic;html=1;strokeColor=#6c8ebf;strokeWidth=2;"
                edge="1" parent="1" source="rev_xT" target="rev_x3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rev_a32" style="endArrow=classic;html=1;strokeColor=#6c8ebf;strokeWidth=2;"
                edge="1" parent="1" source="rev_x3" target="rev_x2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rev_a21" style="endArrow=classic;html=1;strokeColor=#6c8ebf;strokeWidth=2;"
                edge="1" parent="1" source="rev_x2" target="rev_x1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rev_a10" style="endArrow=classic;html=1;strokeColor=#6c8ebf;strokeWidth=2;"
                edge="1" parent="1" source="rev_x1" target="rev_x0">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ====== U-Net 节区 ====== -->
        <mxCell id="unet_bar" value="③ U-Net 去噪器 —— 每个反向 step 都调用同一网络（输入 x_t、t，输出预测噪声 ε）"
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d6b656;strokeColor=#d6b656;fontColor=#FFFFFF;fontSize=13;fontStyle=1;align=left;spacingLeft=15;"
                vertex="1" parent="1">
          <mxGeometry x="50" y="600" width="1040" height="28" as="geometry" />
        </mxCell>

        <mxCell id="unet_enc" value="&lt;b&gt;Encoder 块&lt;/b&gt;&lt;br&gt;&lt;br&gt;下采样路径&lt;br&gt;&lt;span style='font-size:10px;color:#555;'&gt;Conv + ResBlocks&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="150" y="650" width="240" height="140" as="geometry" />
        </mxCell>

        <mxCell id="unet_mid" value="&lt;b&gt;Bottleneck 瓶颈层&lt;/b&gt;&lt;br&gt;&lt;br&gt;self-attention&lt;br&gt;&lt;span style='font-size:10px;color:#555;'&gt;+ time embedding&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="500" y="650" width="240" height="140" as="geometry" />
        </mxCell>

        <mxCell id="unet_dec" value="&lt;b&gt;Decoder 块&lt;/b&gt;&lt;br&gt;&lt;br&gt;上采样路径&lt;br&gt;&lt;span style='font-size:10px;color:#555;'&gt;ConvTranspose + ResBlocks&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="850" y="650" width="240" height="140" as="geometry" />
        </mxCell>

        <!-- U-Net 内部数据流 + 跳跃连接 -->
        <mxCell id="unet_e_m" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d6b656;strokeWidth=2;"
                edge="1" parent="1" source="unet_enc" target="unet_mid">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="unet_m_d" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d6b656;strokeWidth=2;"
                edge="1" parent="1" source="unet_mid" target="unet_dec">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="unet_skip" value="跳跃连接 (skip connection)"
                style="endArrow=classic;html=1;exitX=0.5;exitY=0;entryX=0.5;entryY=0;strokeColor=#9673a6;strokeWidth=2;dashed=1;fontSize=10;"
                edge="1" parent="1" source="unet_enc" target="unet_dec">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="270" y="620" />
              <mxPoint x="970" y="620" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ====== 标注：每个反向 step 都调用 U-Net ====== -->
        <mxCell id="invoke_1" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.2;entryY=0;strokeColor=#d6b656;strokeWidth=1.5;dashed=1;"
                edge="1" parent="1" source="rev_xT" target="unet_enc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="invoke_2" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.4;entryY=0;strokeColor=#d6b656;strokeWidth=1.5;dashed=1;"
                edge="1" parent="1" source="rev_x3" target="unet_enc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="invoke_3" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.6;entryY=0;strokeColor=#d6b656;strokeWidth=1.5;dashed=1;"
                edge="1" parent="1" source="rev_x2" target="unet_mid">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="invoke_4" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.6;entryY=0;strokeColor=#d6b656;strokeWidth=1.5;dashed=1;"
                edge="1" parent="1" source="rev_x1" target="unet_dec">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 调度同时控制前向与反向两个过程 -->
        <mxCell id="sched_to_fwd" style="endArrow=classic;html=1;exitX=0.3;exitY=1;entryX=0.5;entryY=0;strokeColor=#9673a6;strokeWidth=1.5;dashed=1;"
                edge="1" parent="1" source="schedule" target="fwd_bar">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sched_to_rev" style="endArrow=classic;html=1;exitX=0.7;exitY=1;entryX=0.5;entryY=0;strokeColor=#9673a6;strokeWidth=1.5;dashed=1;"
                edge="1" parent="1" source="schedule" target="rev_bar">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 底部注释：仿真中的应用相关性 -->
        <mxCell id="footnote" value="&lt;i&gt;本文仿真中：每个 diffusion 请求执行 steps_default 个反向去噪步骤（如 SDXL = 30），每一步都是一次 U-Net 前向传播。&lt;/i&gt;"
                style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#666;"
                vertex="1" parent="1">
          <mxGeometry x="100" y="830" width="990" height="30" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
