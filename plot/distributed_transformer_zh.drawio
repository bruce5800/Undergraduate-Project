                vertex="1" parent="1">
          <mxGeometry x="120" y="20" width="900" height="30" as="geometry" />
        </mxCell>

        <!-- ====== 节区横条 ====== -->
        <mxCell id="sec_bar" value="跨 DP / TP / PP 的前向 + 反向 + 参数同步"
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#666666;strokeColor=#666666;fontColor=#FFFFFF;fontSize=13;fontStyle=1;align=left;spacingLeft=15;"
                vertex="1" parent="1">
          <mxGeometry x="120" y="70" width="900" height="28" as="geometry" />
        </mxCell>

        <!-- ====== 输入层 ====== -->
        <mxCell id="input_layer" value="&lt;b&gt;输入层 (Input Layer)&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:11px;color:#555;'&gt;数据并行 (DP)：batch 在 N 个 worker 间切分&lt;/span&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;verticalAlign=middle;align=center;"
                vertex="1" parent="1">
          <mxGeometry x="345" y="120" width="450" height="70" as="geometry" />
        </mxCell>

        <!-- ====== 嵌入层 ====== -->
        <mxCell id="embed_layer" value="&lt;b&gt;嵌入层 (Embedding Layer)&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:11px;color:#555;'&gt;张量并行 (TP)：词表矩阵按 TP 维度切片&lt;/span&gt;"
