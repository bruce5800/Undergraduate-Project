        </mxCell>

        <mxCell id="enc_s3" value="&lt;b&gt;PP Stage 3&lt;/b&gt;&lt;br&gt;&lt;br&gt;层 9 — 12&lt;br&gt;&lt;span style='font-size:11px;color:#555;'&gt;（设备 3）&lt;/span&gt;"
