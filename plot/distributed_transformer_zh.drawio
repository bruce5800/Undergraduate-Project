        <mxCell id="enc_s1" value="&lt;b&gt;PP Stage 1&lt;/b&gt;&lt;br&gt;&lt;br&gt;层 1 — 4&lt;br&gt;&lt;span style='font-size:11px;color:#555;'&gt;（设备 1）&lt;/span&gt;"
