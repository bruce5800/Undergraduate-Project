  <diagram name="Distributed Transformer Training (ZH)" id="fig-transformer-zh">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1140" pageHeight="1060" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ====== 标题（居中于内容 x:120-1020 -> 中心 570） ====== -->
        <mxCell id="title" value="分布式 Transformer 训练：DP + TP + PP 组合（背景知识）"
