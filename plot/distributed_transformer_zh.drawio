        <mxCell id="enc_s2" value="&lt;b&gt;PP Stage 2&lt;/b&gt;&lt;br&gt;&lt;br&gt;层 5 — 8&lt;br&gt;&lt;span style='font-size:11px;color:#555;'&gt;（设备 2）&lt;/span&gt;"
