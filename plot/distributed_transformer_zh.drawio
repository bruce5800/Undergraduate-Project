                vertex="1" parent="1">
          <mxGeometry x="295" y="230" width="550" height="70" as="geometry" />
        </mxCell>

        <!-- ====== Encoder 节区 ====== -->
        <mxCell id="enc_bar" value="① Encoder —— 流水线并行 (PP)（12 层切成 3 个 stage，每 stage 一个设备）"
